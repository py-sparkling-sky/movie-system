# ========================================
# 观影系统环境变量配置模板
# ========================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置值
# 3. TMDB API Key 需要在 https://www.themoviedb.org/ 申请

# ========================================
# 服务器配置
# ========================================
PORT=3000

# ========================================
# 数据库配置
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=movie_watching_system
DB_USER=root
DB_PASSWORD=your_password

# ========================================
# JWT配置
# ========================================
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ========================================
# 管理员初始账号
# ========================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

# ========================================
# TMDB API配置
# ========================================
# TMDB API Key（必填）
# 申请地址：https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# TMDB API基础URL（可选，默认值如下）
TMDB_BASE_URL=https://api.themoviedb.org/3

# TMDB图片URL基础路径（可选，默认值如下）
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# ========================================
# 缓存配置
# ========================================
# 是否启用缓存（true/false）
CACHE_ENABLED=true

# 缓存过期时间（秒），默认1小时
CACHE_TTL=3600

# ========================================
# API限流配置
# ========================================
# TMDB API请求间隔（毫秒），避免超过限流
TMDB_REQUEST_INTERVAL=250

# 每分钟最大请求数
TMDB_MAX_REQUESTS_PER_MINUTE=40
